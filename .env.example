# ─── Cave à Vin — Backend environment variables ───────────────────────────────
# Copier ce fichier en ".env" pour le développement local
# Sur Render : ajouter ces variables dans Environment > Environment Variables
# ⚠️  Ne jamais committer le vrai fichier .env — il est dans .gitignore

NODE_ENV=production
PORT=3000

# MongoDB Atlas — générer une nouvelle URI depuis atlas.mongodb.com
# Format : mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=cave-a-vin
MONGODB_DB=cave-a-vin

# JWT — générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<generate-a-strong-random-secret-min-32-chars>

# Brevo — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=<your-brevo-api-key>
BREVO_SENDER_EMAIL=<your-verified-sender@example.com>

# Anthropic Claude (optionnel — scan étiquettes)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=<your-anthropic-key>

# OCR.Space (optionnel — fallback scan si pas de clé Anthropic)
# https://ocr.space/ocrapi
OCR_SPACE_KEY=<your-ocr-space-key>
